{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "PHP: Install & Run",
            "type": "node-terminal",
            "request": "launch",
            "command": "./setup-php.sh",
            "cwd": "${workspaceFolder}",
            "serverReadyAction": {
                "pattern": "Starting PHP server on (http://\\S+)",
                "uriFormat": "%s",
                "action": "openExternally"
            }
        }
    ]
}